# AI Provider: openai, ollama, gemini
AI_PROVIDER=ollama

# OpenAI (falls genutzt)
OPENAI_API_KEY=sk-xxx
AI_MODEL=gpt-3.5-turbo

# Google Gemini (falls genutzt)
GEMINI_API_KEY=your-key-here
AI_MODEL=gemini-1.5-flash

# Ollama (lokal) – keine API Key nötig
# AI_MODEL=llama3.2  # oder mistral, codellama, deepseek-coder
# Beispiel-Token-Placeholder – niemals echte Tokens einchecken
__token__=your-pypi-token-here

# Beispiel für lokale Scan-Konfiguration
# Diese Werte können auch in einer scan.yaml / scan.json Datei verwendet werden.
# Beispiel:
# format: json
# secrets: true
# fail_level: critical
# exclude:
#   - read_file
